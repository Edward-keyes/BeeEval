<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xailab.vehicle.operation.testplatform.dao.QuesStateDao">

    <resultMap type="com.xailab.vehicle.operation.testplatform.entity.QuesStateEntity" id="quesStateMap">
        <result property="id" column="id"/>
        <result property="uid" column="uid"/>
        <result property="stateId" column="state_id"/>
        <result property="quesId" column="ques_id"/>
        <result property="other" column="other"/>
        <result property="optionType" column="option_type"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <select id="queryQuesStateInfo"
            resultType="com.xailab.vehicle.operation.testplatform.pojo.response.FunctionTreeCaseStateEvaluateInfo">
        select qs.id, qs.state_id, qs.ques_id, qs.other, qs.option_type, tq.category_type, tq.question_dimension
        from ques_state qs
                 LEFT JOIN test_ques tq on tq.id = qs.ques_id
        where qs.state_id = #{testStateId}
    </select>

</mapper>