<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xailab.vehicle.operation.testplatform.dao.ProcessStateDao">

    <resultMap type="com.xailab.vehicle.operation.testplatform.entity.ProcessStateEntity" id="processStateMap">
        <result property="id" column="id"/>
        <result property="uid" column="uid"/>
        <result property="stateId" column="state_id"/>
        <result property="processId" column="process_id"/>
        <result property="isSuccess" column="is_success"/>
        <result property="other" column="other"/>
        <result property="errorSelect" column="error_select"/>
        <result property="error" column="error"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <select id="findProcessStateInfo"
            resultType="com.xailab.vehicle.operation.testplatform.pojo.response.FunctionTreeCaseStateCheckInfo">
        select ps.*,
               tp.process_title,
               tp.description,
               tp.step,
               tp.options_type,
               tp.tip,
               tp.ques_one,
               tp.ques_two,
               tp.ques_three
        from process_state ps
                 left join test_process tp on ps.process_id = tp.id
        where ps.state_id = #{stateId}
    </select>

</mapper>