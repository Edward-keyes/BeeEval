<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xailab.vehicle.operation.testplatform.dao.ProcessStateOptionsDao">

    <resultMap type="com.xailab.vehicle.operation.testplatform.entity.ProcessStateOptionsEntity" id="processStateOptionsMap">
        <result property="id" column="id"/>
        <result property="processStateId" column="process_state_id"/>
        <result property="selectId" column="select_id"/>
    </resultMap>
    <select id="findProcessStateOptionInfo"
            resultType="com.xailab.vehicle.operation.testplatform.vo.TestProcessOptionsStateVO">
        select pso.*, tpo.`options`, tpo.sort
        from process_state_options pso
                 left join test_process_options tpo on pso.select_id = tpo.id
        where pso.process_state_id = #{processStateId}

    </select>

</mapper>